# Home Assistant
HA_BASE_URL=https://home.example.com
HA_TOKEN=replace_me

# UniFi Site Manager
UNIFI_SITE_MANAGER_API_KEY=replace_me

# Local UniFi Network
UNIFI_NETWORK_BASE_URL=https://unifi-network.example.com
UNIFI_NETWORK_API_KEY=replace_me

# Local UniFi Protect
UNIFI_PROTECT_BASE_URL=https://unifi-protect.example.com
UNIFI_PROTECT_USERNAME=local_admin
UNIFI_PROTECT_PASSWORD=replace_me
UNIFI_PROTECT_API_KEY=replace_me_if_available

# Runtime
VERIFY_SSL=true
REQUEST_TIMEOUT_SECONDS=20
